NEXT_PUBLIC_SUPABASE_URL=https://jynkglmuzdounpavahko.supabase.co

# Public browser-safe Supabase key.
# This can be exposed to frontend code, but database access must still be protected by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Server-only secret. Never expose in browser code, never prefix with NEXT_PUBLIC_,
# never commit a real value to git, and rotate immediately if leaked.
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
